{
    "version": "2.0.0",
    "presentation": {
        "reveal": "always",
        "panel": "shared"
    },
    "problemMatcher": [],
    "tasks": [
        {
            "label": "YAPF",
            "type": "shell",
            "group": "none",
            "command": "${workspaceFolder}/Fuzz/.venv/Scripts/yapf.exe",
            "args": [
                "--style",
                "${workspaceFolder}/Fuzz/.style.yapf",
                "--recursive",
                "--in-place",
                "--parallel",
                "${workspaceFolder}/Fuzz",
                 "--exclude",
                 "${workspaceFolder}/Fuzz/.venv/**",
            ]
        },
        {
            "label": "sewing table frame: export.step-from-part",
            "type": "shell",
            "group": "none",
            "command": "${workspaceFolder}/Fuzz/.venv/Scripts/invoke.exe",
            "options": {
                "cwd": "${workspaceFolder}/Fuzz"
            },
            "args": [
                "export.step-from-part",
                "--path",
                "${workspaceFolder}/Projects/КВАРТИРА/Швейный стол/Стол-Письменный-Швейный-Каркас.SLDPRT",
                "--save-subfolder",
                "STEP"
            ],
        },
        {
            "label": "sewing table frame: export.step-from-assembly",
            "type": "shell",
            "group": "none",
            "command": "${workspaceFolder}/Fuzz/.venv/Scripts/invoke.exe",
            "options": {
                "cwd": "${workspaceFolder}/Fuzz"
            },
            "args": [
                "export.step-from-assembly",
                "--path",
                "${workspaceFolder}/Projects/КВАРТИРА/Швейный стол/Стол-Письменный-Швейный.SLDASM",
                "--save-subfolder",
                "STEP"
            ],
        }
    ]
}